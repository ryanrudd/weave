use weave::crdt::SiteId;
use weave::repository::Repository;
use weave::strategy::LineCRDT;

fn main() {
    let mut repo = Repository::new(SiteId(1), LineCRDT::new);

    // Shared base
    {
        let doc = repo.open_file("shared.txt");
        doc.append("base line".into());
    }
    repo.commit("Initial content");
    println!("After initial commit, main: {:?}", repo.read_file("shared.txt"));

    // Create feature branch
    repo.create_branch("feature");

    // Add on main
    {
        let doc = repo.open_file("shared.txt");
        doc.append("added on main".into());
    }
    repo.commit("Edit on main");
    println!("After main edit: {:?}", repo.read_file("shared.txt"));

    // Switch to feature
    repo.checkout("feature").unwrap();
    println!("After checkout feature: {:?}", repo.read_file("shared.txt"));

    {
        let doc = repo.open_file("shared.txt");
        doc.append("added on feature".into());
    }
    repo.commit("Edit on feature");
    println!("After feature edit: {:?}", repo.read_file("shared.txt"));

    // Switch back to main
    repo.checkout("main").unwrap();
    println!("After checkout main: {:?}", repo.read_file("shared.txt"));

    // Merge
    let merge_id = repo.merge("feature").unwrap();
    println!("After merge: {:?}", repo.read_file("shared.txt"));
}
